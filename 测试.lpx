#!name = 可莉资源浏览器访问修复
#!desc = 解决 Kelee.one 的 WAF 拦截、乱码及强制下载问题。
#!author = 阿豪
#!icon = https://raw.githubusercontent.com/luestr/IconCenter/master/Apps/Kelee.png

[Rewrite]
# 1. 伪装 UA (请求头)
^https?:\/\/kelee\.one header-replace User-Agent "StashCore/2.7.1 Stash/2.7.1 Clash/1.11.0"

# 2. 强制内联显示 (响应头)
^https?:\/\/kelee\.one header-replace Content-Disposition "inline"

# 3. 强制 UTF-8 (响应头)
^https?:\/\/kelee\.one header-replace Content-Type "text/plain;charset=utf-8"

[MITM]
hostname = kelee.one
