#!name = 百度首页净化
#!desc = 严格按照图片配置封装。
#!author = w-1349
#!icon = https://raw.githubusercontent.com/lige47/Loon-Gallery/main/Icon/Baidu.png

[Script]
# 核心配置：使用引号包裹正则表达式确保解析准确
# 虽然你图片里“需要响应 Body”没开，但你的 JS 代码逻辑是替换 body，所以插件里必须写 requires-body=true
http-response "^https?:\/\/(www|m)\.baidu\.com\/?($|\?from=\w{8,9})" script-path=https://raw.githubusercontent.com/w-1349/scripts/main/JS/baidu.js, requires-body=true, tag=百度首页净化, timeout=20

[MITM]
hostname = www.baidu.com, m.baidu.com
