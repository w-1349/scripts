#!name = 可莉资源浏览器访问
#!desc = 支持可莉资源浏览器的访问，绕过浏览器访问 WAF 拦截，通过修改请求和响应头适配特定客户端需求。
#!author = yaowuliu

[MITM]
hostname = kelee.one

[Rewrite]
# 替换请求头 User-Agent（伪装成 Stash 客户端）
^https://kelee\.one header-replace User-Agent StashCore/2.7.1

# 添加响应头 Content-Disposition: inline
^https://kelee\.one response-header-add Content-Disposition inline

# 替换响应头 Content-Type 为 text/plain;charset=utf-8
^https://kelee\.one response-header-replace Content-Type text/plain;charset=utf-8
