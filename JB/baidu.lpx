#!name = 可莉资源浏览器访问
#!desc = 支持可莉资源浏览器的访问，绕过浏览器访问 WAF 拦截
#!author = yaowuliu

[MITM]
hostname = kelee.one

[Header Rewrite]
# 替换请求头 User-Agent
^https://kelee\.one header-replace User-Agent StashCore/2.7.1 Stash/2.7.1 Clash/1.11.0

# 添加响应头 Content-Disposition
^https://kelee\.one header-add Content-Disposition inline

# 替换响应头 Content-Type
^https://kelee\.one header-replace-dict response Content-Type text/plain;charset=utf-8
