#!name = 可莉资源浏览器访问
#!desc = 支持可莉资源浏览器的访问，绕过浏览器访问 WAF 拦截，通过修改请求和响应头适配特定客户端需求。
#!author = yaowuliu
#!icon = https://kelee.one/favicon.ico

[MITM]
hostname = kelee.one

[Header Rewrite]
# 替换请求头 User-Agent
^https://kelee\.one header-replace User-Agent StashCore/2.7.1 Stash/2.7.1 Clash/1.11.0

# 添加响应头 Content-Disposition
^https://kelee\.one header-add Content-Disposition inline

# 替换响应头 Content-Type（仅当存在时替换）
^https://kelee\.one header-replace Content-Type text/plain;charset=utf-8
