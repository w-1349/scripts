#!name = 可莉资源浏览器访问
#!desc = 可莉资源绕过浏览器 WAF 拦截
#!author = w-1349

[MITM]
hostname = kelee.one

[Rewrite]
# 替换请求头 User-Agent（伪装成代理客户端）
^https://kelee\.one header-replace User-Agent StashCore/2.7.1 Stash/2.7.1 Clash/1.11.0

# 替换响应头 Content-Disposition 为 inline（强制网页内显示，覆盖服务器的 attachment）
^https://kelee\.one response-header-replace Content-Disposition inline

# 替换响应头 Content-Type 为 text/plain;charset=utf-8
^https://kelee\.one response-header-replace Content-Type text/plain;charset=utf-8
