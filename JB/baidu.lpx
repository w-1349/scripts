#!name = 可莉资源绕过waf
#!desc = 支持可莉资源浏览器的访问，绕过浏览器访问 WAF 拦截
#!author = yaowuliu

[MITM]
hostname = kelee.one

[Rewrite]
# type: request, replace User-Agent
^https://kelee\.one header-replace User-Agent StashCore/2.7.1%20Stash/2.7.1%20Clash/1.11.0

# type: response, add Content-Disposition
^https://kelee\.one response-header-add Content-Disposition inline

# type: response, replace Content-Type
^https://kelee\.one response-header-replace Content-Type text/plain;charset=utf-8
