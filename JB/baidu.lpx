#!name = 可莉资源浏览器访问
#!desc = 支持可莉资源浏览器的访问，绕过浏览器访问 WAF 拦截，通过修改请求和响应头适配特定客户端需求。
#!author = yaowuliu

[MITM]
hostname = kelee.one

[Rewrite]
# 替换 User-Agent 为 Stash 客户端
^https://kelee\.one header-replace User-Agent StashCore/2.7.1 Stash/2.7.1 Clash/1.11.0

# 删除浏览器特征头（关键！）
^https://kelee\.one header-del sec-fetch-site
^https://kelee\.one header-del sec-fetch-mode
^https://kelee\.one header-del sec-fetch-dest
^https://kelee\.one header-del upgrade-insecure-requests

# 添加 Content-Disposition: inline
^https://kelee\.one response-header-add Content-Disposition inline

# 替换 Content-Type
^https://kelee\.one response-header-replace Content-Type text/plain;charset=utf-8
